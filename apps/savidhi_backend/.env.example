# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=savidhi
POSTGRES_USER=savidhi_user
POSTGRES_PASSWORD=savidhi_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:8081

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Shiprocket (puja prasad hamper shipping) ────────────────────────────────
# Used by booking-service. Leave FEATURE_SHIPROCKET_ENABLED=false to disable
# the integration entirely — the admin "Ship Prashad" button degrades to a
# clear "not configured" state and no outbound calls are made.
FEATURE_SHIPROCKET_ENABLED=false
SHIPROCKET_API_BASE=https://apiv2.shiprocket.in
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Nickname registered in Shiprocket panel → Settings → Pickup Addresses.
SHIPROCKET_PICKUP_NICKNAME=work
# Custom channel id from Shiprocket panel → Settings → Channels.
SHIPROCKET_CHANNEL_ID=
# Shared secret. Same string must be saved in Shiprocket panel → Settings → API
# → Configure Webhooks → Token (Auth Token Type = x-api-key). Generate with
# `openssl rand -hex 32`.
SHIPROCKET_WEBHOOK_SECRET=
