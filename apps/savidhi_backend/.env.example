# ──────────────────────────────────────────────────────────────────────────────
# Savidhi backend — environment template
#
# Copy to `.env` in this directory and fill in. `docker-compose.yml` reads this
# file directly (via ${VAR:-default} interpolation) and forwards keys into each
# microservice container.
#
# Three categories of keys:
#   [LOCAL]    Has a safe default — leave blank or use the value shown.
#   [STUBBED]  Integration is disabled by a feature flag locally; real creds
#              only required in prod.
#   [REQUIRED] Must be set for that feature to work at all.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Node / Compose ───────────────────────────────────────────────────────────
NODE_ENV=development                                            # [LOCAL]
POSTGRES_DB=savidhi                                             # [LOCAL]
POSTGRES_USER=savidhi_user                                      # [LOCAL]
POSTGRES_PASSWORD=savidhi_password                              # [LOCAL]
# Comma-separated allowed origins. Defaults already cover web (3001), admin
# (3002), and Metro (8081).
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:8081

# ─── Rate limiting (gateway-service) ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000                                     # [LOCAL] 15 min
RATE_LIMIT_MAX_REQUESTS=100                                     # [LOCAL]

# ─── JWT (auth-service) ───────────────────────────────────────────────────────
# Min 32 chars each. Used to sign access + refresh tokens.
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars          # [REQUIRED]
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars        # [REQUIRED]
JWT_ACCESS_EXPIRES=1h                                           # [LOCAL]
JWT_REFRESH_EXPIRES=7d                                          # [LOCAL]
# Set to a parent domain (e.g. `.savidhi.in`) in prod to share auth cookies
# across subdomains. Leave blank locally — cookies stick to localhost.
AUTH_COOKIE_DOMAIN=                                             # [STUBBED]

# ─── Razorpay (booking-service, payments) ─────────────────────────────────────
# Local dev: set PAYMENTS_FORCE_STUB=true to bypass real Razorpay — the booking
# flow then auto-marks orders as paid so you can exercise the materializer
# without keys. Test keys live in memory: project_razorpay_creds.md.
PAYMENTS_FORCE_STUB=true                                        # [LOCAL]
RAZORPAY_KEY_ID=                                                # [STUBBED]
RAZORPAY_KEY_SECRET=                                            # [STUBBED]
# Shared secret configured in Razorpay dashboard → Webhooks. Generate with
# `openssl rand -hex 32`. Required for /payments/webhook to accept events.
RAZORPAY_WEBHOOK_SECRET=                                        # [STUBBED]

# ─── Shiprocket (booking-service, puja-prasad shipping) ───────────────────────
# Disabled by default. When false, the admin "Ship Prashad" button shows
# "not configured" and no outbound calls are made. Real creds: memory file
# project_shiprocket_creds.md.
FEATURE_SHIPROCKET_ENABLED=false                                # [LOCAL]
SHIPROCKET_API_BASE=https://apiv2.shiprocket.in                 # [LOCAL]
SHIPROCKET_EMAIL=                                               # [STUBBED]
SHIPROCKET_PASSWORD=                                            # [STUBBED]
# Nickname registered in Shiprocket panel → Settings → Pickup Addresses.
SHIPROCKET_PICKUP_NICKNAME=work                                 # [STUBBED]
# Custom channel id from Shiprocket panel → Settings → Channels.
SHIPROCKET_CHANNEL_ID=                                          # [STUBBED]
# Shared secret. Same string must be saved in Shiprocket panel → Settings → API
# → Configure Webhooks → Token (Auth Token Type = x-api-key). Generate with
# `openssl rand -hex 32`.
SHIPROCKET_WEBHOOK_SECRET=                                      # [STUBBED]

# ─── Prokerala (catalog-service, panchang / tithi) ────────────────────────────
# When blank, catalog responses fall back to static seed data. Fine for local;
# required for prod muhurat accuracy.
PROKERALA_CLIENT_ID=                                            # [STUBBED]
PROKERALA_CLIENT_SECRET=                                        # [STUBBED]

# ─── Twilio (auth-service OTP + notification-service SMS/WhatsApp) ────────────
# When blank, auth-service stubs OTP — it logs the code to stdout instead of
# texting it. Useful for local without burning Twilio quota.
TWILIO_ACCOUNT_SID=                                             # [STUBBED]
TWILIO_AUTH_TOKEN=                                              # [STUBBED]
TWILIO_VERIFY_SERVICE_SID=                                      # [STUBBED]
# Notification-service senders. Leave blank locally; SMS/WhatsApp sends no-op.
TWILIO_SMS_FROM=                                                # [STUBBED]
TWILIO_WHATSAPP_FROM=                                           # [STUBBED]

# ─── SMTP (notification-service, transactional email) ─────────────────────────
# When SMTP_HOST is blank, email sends no-op (logs the would-be send). Use any
# provider (SendGrid, Mailgun, AWS SES via SMTP, etc.).
SMTP_HOST=                                                      # [STUBBED]
SMTP_PORT=587                                                   # [LOCAL]
SMTP_USER=                                                      # [STUBBED]
SMTP_PASS=                                                      # [STUBBED]
SMTP_FROM=Savidhi <no-reply@savidhi.in>                         # [LOCAL]

# ─── FCM (notification-service, mobile push) ──────────────────────────────────
# Firebase Admin SDK service-account JSON, single-line. When blank, push sends
# no-op (logged). Get from Firebase Console → Project Settings → Service Accounts.
FCM_SERVICE_ACCOUNT_JSON=                                       # [STUBBED]

# ─── Media storage (media-service) ────────────────────────────────────────────
# Local: MinIO (S3-compatible, runs as a docker-compose service). Defaults
# below match docker-compose; only override if you point at a different bucket.
S3_BUCKET=savidhi-media                                         # [LOCAL]
S3_REGION=ap-south-1                                            # [LOCAL]
AWS_ACCESS_KEY_ID=minioadmin                                    # [LOCAL]
AWS_SECRET_ACCESS_KEY=minioadmin                                # [LOCAL]
# Prod uses Google Cloud Storage instead — these are read by media-service
# when set. Leave commented locally.
# GCS_MEDIA_BUCKET=savidhi-media-prod                           # [STUBBED]
# GCS_UPLOAD_BUCKET=savidhi-uploads-prod                        # [STUBBED]
# Fallback for the local filesystem path inside the container.
UPLOAD_DIR=/app/uploads                                         # [LOCAL]

# ─── Worker / feature toggles (booking-service) ───────────────────────────────
# These workers run inside booking-service when enabled. In prod they run as
# k8s CronJobs (see apps/savidhi_backend/k8s/30/31-cronjob-*.yaml) instead, so
# they're typically OFF in the booking-service container.
# Locally, set to "true" only if you want them ticking inside docker-compose.
RUN_EXPIRE_PAYMENTS_WORKER=false                                # [LOCAL]
RUN_AUTOCOMPLETE_WORKER=false                                   # [LOCAL]
SUBSCRIPTION_ROLLOVER_VERBOSE=false                             # [LOCAL]

# ─── Internal service URLs ────────────────────────────────────────────────────
# The defaults in docker-compose.yml already point at the right Docker DNS
# names (e.g. http://auth-service:4001). Only override if you run a service
# OUTSIDE docker-compose (e.g. attaching a debugger to one service on host).
# AUTH_SERVICE_URL=http://auth-service:4001
# USER_SERVICE_URL=http://user-service:4002
# CATALOG_SERVICE_URL=http://catalog-service:4003
# BOOKING_SERVICE_URL=http://booking-service:4004
# MEDIA_SERVICE_URL=http://media-service:4005
# NOTIFICATION_SERVICE_URL=http://notification-service:4006

# ─── Keys you DON'T need to set in .env ───────────────────────────────────────
# These are read by service code but populated by `docker-compose.yml`'s
# per-service `environment:` block, not by this file. Listed here just so a
# grep for "process.env.X" in the services matches a sane answer:
#   DB_HOST=postgres               (set per-service; uses container DNS)
#   DB_NAME, DB_USER, DB_PASSWORD  (derived from POSTGRES_* above)
#   DB_PORT=5432
#   REDIS_URL=redis://redis:6379   (set per-service)
#   PORT=400N                      (per-service: 4001 auth, 4002 user, …)
#   S3_ENDPOINT=http://minio:9000  (media-service only)
#   DATABASE_URL                   (alt form used by some scripts; not required)
# Only override these if you're running a service OUTSIDE docker-compose.

# ─── Translations (catalog-service) ───────────────────────────────────────────
# Uses Google Cloud Translation v2 via Application Default Credentials (ADC).
# In prod: GKE Workload Identity binds the pod SA to a GCP SA with
# roles/cloudtranslate.user. Locally: leave blank — translate.ts silently
# falls back to the canonical column when the API call fails, so the catalog
# still renders. To exercise translations locally, run:
#   gcloud auth application-default login
# then mount ~/.config/gcloud into the catalog-service container.
