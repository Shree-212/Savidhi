# API Gateway URL (proxied through Next.js rewrites at /api/*)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Conversion-tracking pixel IDs. Leave blank in non-prod environments — the
# layout only injects the scripts when these are populated. Events fired via
# src/lib/analytics.ts will simply no-op without pixels loaded.
#
# NEXT_PUBLIC_META_PIXEL_ID=  # e.g. 1234567890123456
# NEXT_PUBLIC_GA4_ID=         # e.g. G-XXXXXXXXXX (GA4 / Google Ads gtag.js)
