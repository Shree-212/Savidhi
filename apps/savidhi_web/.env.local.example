# ──────────────────────────────────────────────────────────────────────────────
# savidhi_web — local environment template
# Copy to `.env.local` and fill in. Next.js loads it automatically.
# ──────────────────────────────────────────────────────────────────────────────

# API Gateway URL. Web hits this via the Next.js rewrite at /api/*
# (see apps/savidhi_web/next.config.js).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public site URL — used by canonical/og:url tags and the sitemap.
# Set to https://savidhi.in in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Admin URL referenced by a handful of "open in admin" links. Optional.
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# ─── Conversion tracking ─────────────────────────────────────────────────────
# Meta Pixel — the same id that's set as META_PIXEL_ID on the backend's .env
# (the server-side CAPI sibling uses it). Dedup against CAPI happens
# automatically via the event_id that src/lib/analytics.ts attaches.
NEXT_PUBLIC_META_PIXEL_ID=1312368787019472

# GA4 / Google Ads measurement id. When set, gtag.js is injected from layout
# and src/lib/analytics.ts mirrors events to it.
NEXT_PUBLIC_GA4_ID=G-SYZ5R45M1S
