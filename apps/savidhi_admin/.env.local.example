# ──────────────────────────────────────────────────────────────────────────────
# savidhi_admin — local environment template
# Copy to `.env.local` and fill in. Next.js loads it automatically.
# ──────────────────────────────────────────────────────────────────────────────

# API Gateway URL (proxied through Next.js rewrites at /api/*).
# Only NEXT_PUBLIC_API_URL is consumed at build time (see src/lib/env.ts).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional server-side override for SSR/route handlers running INSIDE Docker
# (when admin runs in the same docker network as the gateway). When unset,
# server-side fetches fall back to NEXT_PUBLIC_API_URL.
# INTERNAL_GATEWAY_URL=http://gateway-service:4000
